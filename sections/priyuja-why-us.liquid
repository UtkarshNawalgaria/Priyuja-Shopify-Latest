<style>
  #shopify-section-{{ section.id }} {
    --cream: var(--priyuja-cream);
    --maroon: var(--priyuja-maroon);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
  }

  #shopify-section-{{ section.id }} .priyuja-why {
    background: #fff;
    padding: 100px 48px;
    font-family: var(--font-body);
  }

  #shopify-section-{{ section.id }} .priyuja-why__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .priyuja-why__label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .priyuja-why__title {
    font-family: var(--font-heading);
    font-size: 44px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--dark);
    margin: 0 0 60px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .priyuja-why__title em {
    font-style: italic;
    color: var(--maroon);
  }

  #shopify-section-{{ section.id }} .priyuja-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .priyuja-why__card {
    background: var(--cream);
    border-radius: 12px;
    padding: 36px 28px;
    border-top: 3px solid transparent;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .priyuja-why__card:hover {
    border-top-color: var(--maroon);
    transform: translateY(-4px);
  }

  #shopify-section-{{ section.id }} .priyuja-why__card-icon {
    font-size: 32px;
    margin-bottom: 20px;
    display: block;
  }

  #shopify-section-{{ section.id }} .priyuja-why__card-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .priyuja-why__card-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-mid);
  }

  @media (max-width: 1100px) {
    #shopify-section-{{ section.id }} .priyuja-why__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .priyuja-why {
      padding: 60px 24px;
    }

    #shopify-section-{{ section.id }} .priyuja-why__title {
      font-size: 32px;
    }

    #shopify-section-{{ section.id }} .priyuja-why__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="priyuja-why">
  <div class="priyuja-why__inner">
    <div class="priyuja-why__label reveal">{{ section.settings.section_label }}</div>
    <h2 class="priyuja-why__title reveal">
      {{ section.settings.h2_line1 }}<br>
      <em>{{ section.settings.h2_line2 }}</em>
    </h2>

    <div class="priyuja-why__grid">
      {%- for block in section.blocks -%}
        <div class="priyuja-why__card reveal" {{ block.shopify_attributes }}>
          <span class="priyuja-why__card-icon">{{ block.settings.icon }}</span>
          <div class="priyuja-why__card-title">{{ block.settings.title }}</div>
          <div class="priyuja-why__card-desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var reveals = section.querySelectorAll('.reveal');
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    reveals.forEach(function(el, i) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s ease ' + (i * 0.1) + 's, transform 0.6s ease ' + (i * 0.1) + 's';
      observer.observe(el);
    });
    var style = document.createElement('style');
    style.textContent = '#shopify-section-{{ section.id }} .reveal.visible { opacity: 1 !important; transform: translateY(0) !important; }';
    document.head.appendChild(style);
  })();
</script>

{% schema %}
{
  "name": "Priyuja - Why Us",
  "tag": "section",
  "class": "priyuja-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "Why Priyuja"
    },
    {
      "type": "text",
      "id": "h2_line1",
      "label": "Heading Line 1",
      "default": "Why Boutiques Choose"
    },
    {
      "type": "text",
      "id": "h2_line2",
      "label": "Heading Line 2 (italic)",
      "default": "Priyuja"
    }
  ],
  "blocks": [
    {
      "type": "reason",
      "name": "Reason",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "⭐"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Reason Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of this reason."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Priyuja - Why Us"
    }
  ]
}
{% endschema %}
