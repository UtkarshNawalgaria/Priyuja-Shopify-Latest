<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --maroon-deep: var(--priyuja-maroon-deep);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --gold-light: var(--priyuja-gold-light);
    --gold-pale: var(--priyuja-gold-pale);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --line: var(--priyuja-line, #E6DCC8);
    --card: var(--priyuja-card, #FFFFFF);
    --surface: var(--priyuja-surface, #FFFCF6);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}32px{%- when 'large' -%}96px{%- else -%}54px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}24px{%- when 'large' -%}44px{%- else -%}34px{%- endcase -%};
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  .pvs-offers { font-family: var(--font-body); color: var(--dark); line-height: 1.65; background: var(--cream); padding: var(--section-v-pad) 0; border-bottom: 1px solid var(--line); }
  .pvs-offers h2, .pvs-offers h3 { font-family: var(--font-heading); color: var(--maroon); margin: 0; line-height: 1.12; }
  .pvs-offers__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  .pvs-offers__eyebrow { font-family: var(--font-body); letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold); }
  .pvs-offers__grid { display: grid; grid-template-columns: repeat({{ section.settings.desktop_columns | default: 3 }}, 1fr); gap: 20px; margin-top: 22px; }
  .pvs-offers__card { background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 22px; }
  .pvs-offers__card h3 { font-size: 21px; }
  .pvs-offers__card p { font-size: 14px; color: var(--text-mid); margin-top: 6px; }

  @media (max-width: 820px) {
    .pvs-offers__grid { grid-template-columns: 1fr; }
    .pvs-offers { padding: calc(var(--section-v-pad) * 0.65) 0; }
    .pvs-offers__wrap { padding: 0 18px; }
  }
</style>

<section class="pvs-offers">
  <div class="pvs-offers__wrap">
    <div style="text-align:center;max-width:720px;margin:0 auto 10px;">
      <div class="pvs-offers__eyebrow reveal">{{ section.settings.eyebrow | default: 'From our Varanasi store' }}</div>
      <h2 class="reveal" style="font-size:var(--heading-font-size);margin-top:8px;">{{ section.settings.heading | default: 'Handloom Banarasi silks, and much more' }}</h2>
      <p class="reveal" style="color:var(--text-mid);">{{ section.settings.subheading | default: 'Pure handloom Banarasi silks woven in Varanasi, plus the full Priyuja range of other fabrics — all wholesale, all from one partner.' }}</p>
    </div>
    {%- assign offer_cards = section.blocks | where: 'type', 'card' -%}
    {%- if offer_cards.size > 0 -%}
      <div class="pvs-offers__grid">
        {%- for block in offer_cards -%}
          <div class="pvs-offers__card reveal" {{ block.shopify_attributes }}>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.collections_url != blank -%}
      <p class="reveal" style="text-align:center;margin-top:18px;"><a href="{{ section.settings.collections_url }}" style="font-weight:700;color:var(--maroon);">Browse all fabric collections →</a></p>
    {%- endif -%}
  </div>
</section>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Priyuja - Store Offers",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From our Varanasi store"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handloom Banarasi silks, and much more"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pure handloom Banarasi silks woven in Varanasi, plus the full Priyuja range of other fabrics — all wholesale, all from one partner."
    },
    {
      "type": "url",
      "id": "collections_url",
      "label": "Fabric Collections Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width (100%)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Offer Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Card Text",
          "default": "Card description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Priyuja - Store Offers"
    }
  ]
}
{% endschema %}
