{%- assign fabric = page.metafields.custom.fabric.value -%}
{%- if fabric == blank -%}{%- break -%}{%- endif -%}
{%- assign fabric_name = fabric.name -%}

{%- if fabric.quick_facts == blank or fabric.quick_facts.value.size == 0 -%}{%- break -%}{%- endif -%}

<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --maroon-deep: var(--priyuja-maroon-deep);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --gold-light: var(--priyuja-gold-light);
    --gold-pale: var(--priyuja-gold-pale);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --line: var(--priyuja-line, #E6DCC8);
    --card: var(--priyuja-card, #FFFFFF);
    --surface: var(--priyuja-surface, #FFFCF6);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}32px{%- when 'large' -%}96px{%- else -%}46px{%- endcase -%};
    --section-v-pad-mobile: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}20px{%- when 'large' -%}64px{%- else -%}32px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}24px{%- when 'large' -%}44px{%- else -%}30px{%- endcase -%};
  }

  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  #shopify-section-{{ section.id }} .priyuja-fp-facts { font-family: var(--font-body); color: var(--dark); line-height: 1.65; padding: var(--section-v-pad) 0; border-bottom: 1px solid var(--line); }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__eyebrow { font-family: var(--font-body); letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold); margin-bottom: 18px; }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__grid { display: grid; grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr); gap: 18px; }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__card { background: var(--card); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; padding: 18px; }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__label { font-size: 12px; color: var(--text-light); text-transform: uppercase; letter-spacing: 1px; }
  #shopify-section-{{ section.id }} .priyuja-fp-facts__value { font-size: 18px; color: var(--maroon); font-family: var(--font-heading); font-weight: 600; margin-top: 4px; }

  @media (max-width: 760px) {
    #shopify-section-{{ section.id }} .priyuja-fp-facts__grid { grid-template-columns: repeat(2, 1fr); }
    #shopify-section-{{ section.id }} .priyuja-fp-facts { padding: var(--section-v-pad-mobile) 0; }
    #shopify-section-{{ section.id }} .priyuja-fp-facts__wrap { padding: 0 18px; }
  }
</style>

<section class="priyuja-fp-facts">
  <div class="priyuja-fp-facts__wrap">
    <div class="priyuja-fp-facts__eyebrow reveal">At a glance</div>
    <div class="priyuja-fp-facts__grid">
      {%- for fact in fabric.quick_facts.value -%}
        <div class="priyuja-fp-facts__card reveal">
          <div class="priyuja-fp-facts__label">{{ fact.label }}</div>
          <div class="priyuja-fp-facts__value">{{ fact.value }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Fabric — Quick Facts",
  "tag": "div",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width (100%)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small (24px)" },
        { "value": "medium", "label": "Medium (default)" },
        { "value": "large", "label": "Large (44px)" }
      ],
      "default": "medium"
    }
  ],
  "presets": [
    {
      "name": "Fabric — Quick Facts"
    }
  ]
}
{% endschema %}
