<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --gold: var(--priyuja-gold);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --line: var(--priyuja-line, #E6DCC8);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}24px{%- when 'large' -%}72px{%- else -%}48px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}24px{%- when 'large' -%}44px{%- else -%}30px{%- endcase -%};
  }
  #shopify-section-{{ section.id }} .pst-choose { background: var(--cream); font-family: var(--font-body); padding: var(--section-v-pad) 0; border-bottom: 1px solid var(--line); }
  #shopify-section-{{ section.id }} .pst-choose__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  #shopify-section-{{ section.id }} .pst-choose__inner { }
  #shopify-section-{{ section.id }} .pst-choose__eyebrow { letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold); }
  #shopify-section-{{ section.id }} .pst-choose h2 { font-family: var(--font-heading); font-size: var(--heading-font-size); color: var(--maroon); margin: 6px 0 10px; line-height: 1.12; }
  #shopify-section-{{ section.id }} .pst-choose p { color: var(--text-mid); line-height: 1.65; }
  @media (max-width: 520px) {
    #shopify-section-{{ section.id }} {
      --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}16px{%- when 'large' -%}48px{%- else -%}32px{%- endcase -%};
      --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}20px{%- when 'large' -%}34px{%- else -%}24px{%- endcase -%};
    }
    #shopify-section-{{ section.id }} .pst-choose { padding: var(--section-v-pad) 0; }
    #shopify-section-{{ section.id }} .pst-choose__wrap { padding: 0 18px; }
    #shopify-section-{{ section.id }} .pst-choose h2 { font-size: var(--heading-font-size); }
  }
</style>

<div class="pst-choose">
  <div class="pst-choose__wrap">
    <div class="pst-choose__inner">
      <div class="pst-choose__eyebrow reveal">{{ section.settings.eyebrow | default: 'A quick guide' }}</div>
      <h2 class="reveal">{{ section.settings.heading | default: 'How to choose the right Banarasi fabric' }}</h2>
      <p class="reveal">{{ section.settings.body | default: "For weddings and bridal ranges, pure silks like Katan and tissue carry the richest look. For everyday and office sarees that move quickly in a boutique, georgette, cotton silk and chiffon are the easy sellers. Tussar and linen suit customers who love texture and natural tones, while satin and crepe bring a sleek, contemporary feel. Chanderi and organza sit in between — light and elegant for festive daytime wear." }}</p>
    </div>
  </div>
</div>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Priyuja - How to Choose",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "A quick guide" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How to choose the right Banarasi fabric" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "For weddings and bridal ranges, pure silks like Katan and tissue carry the richest look. For everyday and office sarees that move quickly in a boutique, georgette, cotton silk and chiffon are the easy sellers. Tussar and linen suit customers who love texture and natural tones, while satin and crepe bring a sleek, contemporary feel. Chanderi and organza sit in between — light and elegant for festive daytime wear." },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [],
  "presets": [{ "name": "Priyuja - How to Choose" }]
}
{% endschema %}
