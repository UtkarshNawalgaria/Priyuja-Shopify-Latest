{%- render 'priyuja-fonts' -%}

<style>
  #shopify-section-{{ section.id }} {
    --cream: #F7F2E8;
    --maroon: #6B1628;
    --maroon-light: #8B2035;
    --gold: #C4922A;
    --gold-light: #D4A84A;
    --dark: #1C1209;
    --text-mid: #6B5040;
    --text-light: #9A7A60;
    --font-heading: 'Cormorant Garamond', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  #shopify-section-{{ section.id }} .priyuja-footer {
    background: #0F0B06;
    padding: 80px 48px 40px;
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.6);
  }

  #shopify-section-{{ section.id }} .priyuja-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 48px;
    margin-bottom: 60px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__brand-name {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
    letter-spacing: 1px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__brand-desc {
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__registered {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__col-heading {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 20px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__links li {
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__links a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__links a:hover {
    color: var(--gold);
  }

  #shopify-section-{{ section.id }} .priyuja-footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__copyright {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
  }

  #shopify-section-{{ section.id }} .priyuja-footer__socials {
    display: flex;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    transition: background 0.3s ease;
  }

  #shopify-section-{{ section.id }} .priyuja-footer__social-link:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  #shopify-section-{{ section.id }} .priyuja-footer__social-link svg {
    width: 18px;
    height: 18px;
    fill: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 1100px) {
    #shopify-section-{{ section.id }} .priyuja-footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .priyuja-footer {
      padding: 60px 24px 30px;
    }

    #shopify-section-{{ section.id }} .priyuja-footer__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>

<footer class="priyuja-footer">
  <div class="priyuja-footer__inner">
    <div class="priyuja-footer__grid">
      <div class="priyuja-footer__brand">
        <div class="priyuja-footer__brand-name">{{ section.settings.brand_name }}</div>
        <p class="priyuja-footer__brand-desc">{{ section.settings.brand_description }}</p>
        <div class="priyuja-footer__registered">
          {{ section.settings.registered_name }}<br>
          GST: {{ section.settings.gst_number }}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="priyuja-footer__col" {{ block.shopify_attributes }}>
          <div class="priyuja-footer__col-heading">{{ block.settings.heading }}</div>
          <ul class="priyuja-footer__links">
            {%- for i in (1..6) -%}
              {%- assign label_key = 'link_' | append: i | append: '_label' -%}
              {%- assign url_key = 'link_' | append: i | append: '_url' -%}
              {%- assign label = block.settings[label_key] -%}
              {%- assign url = block.settings[url_key] -%}
              {%- if label != blank -%}
                <li><a href="{{ url }}">{{ label }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>

    <div class="priyuja-footer__bottom">
      <div class="priyuja-footer__copyright">{{ section.settings.copyright_text }}</div>

      <div class="priyuja-footer__socials">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="priyuja-footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="priyuja-footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}

        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" class="priyuja-footer__social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {%- endif -%}

        {%- if section.settings.pinterest_url != blank -%}
          <a href="{{ section.settings.pinterest_url }}" class="priyuja-footer__social-link" target="_blank" rel="noopener" aria-label="Pinterest">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Priyuja - Footer",
  "tag": "section",
  "class": "priyuja-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Priyuja"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Wholesale sarees sourced directly from the master weavers of Varanasi and trusted manufacturers of Surat."
    },
    {
      "type": "text",
      "id": "registered_name",
      "label": "Registered Business Name",
      "default": "Olivecloud Tech Private Limited"
    },
    {
      "type": "text",
      "id": "gst_number",
      "label": "GST Number",
      "default": "27AADCO1764H1ZE"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
