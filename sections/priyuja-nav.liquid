{%- render 'priyuja-fonts' -%}

<style>
  #shopify-section-{{ section.id }} {
    --cream: #F7F2E8;
    --maroon: #6B1628;
    --maroon-light: #8B2035;
    --maroon-deep: #4A0F1C;
    --gold: #C4922A;
    --gold-light: #D4A84A;
    --gold-pale: #F0E0B0;
    --dark: #1C1209;
    --text-mid: #6B5040;
    --text-light: #9A7A60;
    --font-heading: 'Cormorant Garamond', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  #shopify-section-{{ section.id }} .priyuja-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(247, 242, 232, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: box-shadow 0.3s ease, background 0.3s ease;
    font-family: var(--font-body);
  }

  #shopify-section-{{ section.id }} .priyuja-nav.scrolled {
    background: rgba(247, 242, 232, 0.95);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .priyuja-nav__logo {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    color: var(--maroon);
    text-decoration: none;
    letter-spacing: 1px;
  }

  #shopify-section-{{ section.id }} .priyuja-nav__links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #shopify-section-{{ section.id }} .priyuja-nav__links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .priyuja-nav__links a:hover {
    color: var(--maroon);
  }

  #shopify-section-{{ section.id }} .priyuja-nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    background: var(--maroon);
    color: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 50px;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .priyuja-nav__cta:hover {
    background: var(--maroon-light);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .priyuja-nav {
      padding: 12px 20px;
    }

    #shopify-section-{{ section.id }} .priyuja-nav__links {
      display: none;
    }

    #shopify-section-{{ section.id }} .priyuja-nav__cta {
      padding: 8px 18px;
      font-size: 13px;
    }
  }
</style>

<nav class="priyuja-nav" id="priyuja-nav-{{ section.id }}">
  <a href="/" class="priyuja-nav__logo">{{ section.settings.logo_text }}</a>

  <ul class="priyuja-nav__links">
    {%- for i in (1..6) -%}
      {%- assign label_key = 'nav_link_' | append: i | append: '_label' -%}
      {%- assign url_key = 'nav_link_' | append: i | append: '_url' -%}
      {%- assign label = section.settings[label_key] -%}
      {%- assign url = section.settings[url_key] -%}
      {%- if label != blank -%}
        <li><a href="{{ url }}">{{ label }}</a></li>
      {%- endif -%}
    {%- endfor -%}
  </ul>

  <a href="{{ section.settings.cta_url }}" class="priyuja-nav__cta" target="_blank" rel="noopener">
    {{ section.settings.cta_text }}
  </a>
</nav>

<script>
  (function() {
    var nav = document.getElementById('priyuja-nav-{{ section.id }}');
    if (!nav) return;
    window.addEventListener('scroll', function() {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Priyuja - Navigation",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "Priyuja"
    },
    {
      "type": "text",
      "id": "nav_link_1_label",
      "label": "Nav Link 1 Label",
      "default": "Our Legacy"
    },
    {
      "type": "text",
      "id": "nav_link_1_url",
      "label": "Nav Link 1 URL",
