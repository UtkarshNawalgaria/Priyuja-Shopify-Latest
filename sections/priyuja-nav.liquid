    },
    {
      "type": "text",
      "id": "nav_link_2_url",
      "label": "Nav Link 2 URL",
      "default": "#how-it-works"
    },
    {
      "type": "text",
      "id": "nav_link_3_label",
      "label": "Nav Link 3 Label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "nav_link_3_url",
      "label": "Nav Link 3 URL",
      "default": "#collections"
    },
    {
      "type": "text",
      "id": "nav_link_4_label",
      "label": "Nav Link 4 Label",
      "default": "Terms"
    },
    {
      "type": "text",
      "id": "nav_link_4_url",
      "label": "Nav Link 4 URL",
      "default": "#terms"
    },
    {
      "type": "text",
      "id": "nav_link_5_label",
      "label": "Nav Link 5 Label",
      "default": ""
    },
    {
      "type": "text",
      "id": "nav_link_5_url",
      "label": "Nav Link 5 URL",
      "default": ""
    },
    {
      "type": "text",
      "id": "nav_link_6_label",
      "label": "Nav Link 6 Label",
      "default": ""
    },
    {
      "type": "text",
      "id": "nav_link_6_url",
