<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --maroon-deep: var(--priyuja-maroon-deep);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --gold-light: var(--priyuja-gold-light);
    --gold-pale: var(--priyuja-gold-pale);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --line: var(--priyuja-line, #E6DCC8);
    --card: var(--priyuja-card, #FFFFFF);
    --surface: var(--priyuja-surface, #FFFCF6);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}32px{%- when 'large' -%}96px{%- else -%}54px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}24px{%- when 'large' -%}44px{%- else -%}34px{%- endcase -%};
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  .pvs-intro { font-family: var(--font-body); color: var(--dark); line-height: 1.65; background: var(--cream); padding: var(--section-v-pad) 0; border-bottom: 1px solid var(--line); }
  .pvs-intro h2 { font-family: var(--font-heading); color: var(--maroon); margin: 0; line-height: 1.12; }
  .pvs-intro__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  .pvs-intro__eyebrow { font-family: var(--font-body); letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold); }
  .pvs-intro__grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 20px; align-items: center; }
  .pvs-intro__img img { width: 100%; height: 340px; object-fit: cover; display: block; border-radius: 12px; }
  .pvs-intro__img-ph { width: 100%; background: linear-gradient(135deg, var(--maroon-deep) 0%, var(--maroon) 50%, var(--gold) 100%); border-radius: 12px; }

  @media (max-width: 820px) {
    .pvs-intro__grid { grid-template-columns: 1fr !important; }
    .pvs-intro { padding: calc(var(--section-v-pad) * 0.65) 0; }
    .pvs-intro__wrap { padding: 0 18px; }
  }
</style>
{%- if section.settings.reverse_columns -%}
<style>
  #shopify-section-{{ section.id }} .pvs-intro__grid { direction: rtl; }
  #shopify-section-{{ section.id }} .pvs-intro__grid > * { direction: ltr; }
</style>
{%- endif -%}

<section class="pvs-intro">
  <div class="pvs-intro__wrap pvs-intro__grid">
    <div class="pvs-intro__img">
      {%- if section.settings.store_image != blank -%}
        <img src="{{ section.settings.store_image | image_url: width: 700 }}" alt="Priyuja Varanasi Store" loading="lazy" width="700" height="500">
      {%- else -%}
        <div class="pvs-intro__img-ph" style="height:340px;"></div>
      {%- endif -%}
    </div>
    <div>
      <div class="pvs-intro__eyebrow reveal">{{ section.settings.eyebrow | default: 'Now at the source' }}</div>
      <h2 class="reveal" style="font-size:var(--heading-font-size);margin:8px 0 14px;">{{ section.settings.heading | default: 'A Priyuja store in Varanasi' }}</h2>
      <p class="reveal" style="color:var(--text-mid);">{{ section.settings.body_1 | default: 'For years we served boutiques from our Mumbai base. Now, with our own store in Varanasi, we are right where the handloom Banarasi saree is born. That means we select straight from the weavers, see fresh designs first, and pass on true at-source value to you — alongside the same trusted terms, GST billing and 24-hour dispatch you already know us for.' }}</p>
      <p class="reveal" style="color:var(--text-mid);">{{ section.settings.body_2 | default: 'You get the heritage handloom sarees from Varanasi, plus our wider range of other fabrics, all from one wholesale partner.' }}</p>
      {%- if section.settings.store_address != blank -%}
        <p class="reveal" style="color:var(--text-mid);margin-top:14px;">📍 {{ section.settings.store_address }}</p>
      {%- else -%}
        <p style="margin-top:14px;"><span style="background:var(--gold-pale);border:1px dashed var(--gold);color:#6b4a05;font-size:12px;border-radius:6px;padding:2px 8px;font-weight:600;">⚠ Add the real Varanasi store address in section settings</span></p>
      {%- endif -%}
    </div>
  </div>
</section>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Priyuja - Store Intro",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "store_image",
      "label": "Store Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Now at the source"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Priyuja store in Varanasi"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Body Paragraph 1",
      "default": "For years we served boutiques from our Mumbai base. Now, with our own store in Varanasi, we are right where the handloom Banarasi saree is born. That means we select straight from the weavers, see fresh designs first, and pass on true at-source value to you — alongside the same trusted terms, GST billing and 24-hour dispatch you already know us for."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Body Paragraph 2",
      "default": "You get the heritage handloom sarees from Varanasi, plus our wider range of other fabrics, all from one wholesale partner."
    },
    {
      "type": "text",
      "id": "store_address",
      "label": "⚠ Store Address (leave blank until confirmed)",
      "info": "Full Varanasi store address."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width (100%)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Reverse column order",
      "default": false
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "presets": [
    {
      "name": "Priyuja - Store Intro"
    }
  ]
}
{% endschema %}
