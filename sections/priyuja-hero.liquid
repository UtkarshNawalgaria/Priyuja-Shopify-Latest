    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "24hr"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Dispatch Promise"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Priyuja - Hero"
    }
  ]
}
