{%- assign wa_link = section.settings.whatsapp_url | default: 'https://wa.me/919112044277' -%}

<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --maroon-deep: var(--priyuja-maroon-deep);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --gold-light: var(--priyuja-gold-light);
    --gold-pale: var(--priyuja-gold-pale);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --line: var(--priyuja-line, #E6DCC8);
    --card: var(--priyuja-card, #FFFFFF);
    --surface: var(--priyuja-surface, #FFFCF6);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}32px{%- when 'large' -%}96px{%- else -%}54px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}28px{%- when 'large' -%}48px{%- else -%}38px{%- endcase -%};
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  .pvs-custom { font-family: var(--font-body); line-height: 1.65; background: var(--maroon); color: #f3e7d8; padding: var(--section-v-pad) 0; }
  .pvs-custom h2 { font-family: var(--font-heading); color: #fff; margin: 0; line-height: 1.12; }
  .pvs-custom__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  .pvs-custom__eyebrow { font-family: var(--font-body); letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold-light); }
  .pvs-custom__intro { color: #f0e0c8; font-size: 18px; margin: 0 auto; text-align: center; }
  .pvs-custom__grid { display: grid; gap: 20px; }
  .pvs-custom__steps { grid-template-columns: repeat(4, 1fr); margin-top: 26px; }
  .pvs-custom__step { background: var(--maroon-deep); border: 1px solid var(--maroon-light); border-radius: 12px; padding: 22px; color: #f3e7d8; }
  .pvs-custom__step strong { color: var(--gold-light); }
  .pvs-custom__step p { font-size: 14px; color: #e7d3bf; margin-top: 6px; }
  .pvs-custom__num { color: var(--gold); font-family: var(--font-heading); font-size: 30px; font-weight: 700; }
  .pvs-custom__swatch-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 12px; margin-top: 26px; }
  .pvs-custom__swatch { border-radius: 10px; overflow: hidden; text-align: center; }
  .pvs-custom__swatch-color { width: 100%; height: 60px; border-radius: 8px 8px 0 0; }
  .pvs-custom__swatch-name { font-size: 11px; font-weight: 600; color: #f3e7d8; padding: 4px 2px; letter-spacing: .3px; }
  .pvs-custom__btn { display: inline-block; padding: 13px 26px; border-radius: 7px; font-weight: 700; font-size: 14px; text-decoration: none; border: 1.5px solid var(--gold); font-family: var(--font-body); cursor: pointer; transition: background 0.3s ease, transform 0.3s ease; background: var(--gold); color: var(--maroon-deep); }
  .pvs-custom__btn:hover { background: var(--gold-light); transform: translateY(-2px); }

  @media (max-width: 820px) {
    .pvs-custom__steps { grid-template-columns: repeat(2, 1fr); }
    .pvs-custom { padding: calc(var(--section-v-pad) * 0.65) 0; }
    .pvs-custom__wrap { padding: 0 18px; }
    .pvs-custom__swatch-grid { grid-template-columns: repeat(auto-fill, minmax(65px, 1fr)); }
  }
</style>

<section class="pvs-custom" id="pvs-custom">
  <div class="pvs-custom__wrap">
    <div style="text-align:center;margin-bottom:8px;">
      <div class="pvs-custom__eyebrow reveal">{{ section.settings.eyebrow | default: 'Only possible from Varanasi' }}</div>
      <h2 class="reveal" style="font-size:var(--heading-font-size);margin:8px 0 12px;">{{ section.settings.heading | default: 'Choose your own colour' }}</h2>
      <p class="pvs-custom__intro reveal">{{ section.settings.intro | default: 'Pick any shade from our colour chart and we weave it to order at our Varanasi looms — in the exact colour your customers are asking for. This is something we simply could not offer from Mumbai. It lets your boutique stand apart with colours no one else is stocking.' }}</p>
    </div>

    {%- assign custom_steps = section.blocks | where: 'type', 'step' -%}
    {%- if custom_steps.size > 0 -%}
      <div class="pvs-custom__grid pvs-custom__steps">
        {%- for block in custom_steps -%}
          <div class="pvs-custom__step reveal" {{ block.shopify_attributes }}>
            <div class="pvs-custom__num">{{ block.settings.step_number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</div>
            <strong>{{ block.settings.step_title }}</strong>
            <p>{{ block.settings.step_text }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- assign swatches = section.blocks | where: 'type', 'swatch' -%}
    {%- if swatches.size > 0 -%}
      <div class="pvs-custom__swatch-grid reveal">
        {%- for block in swatches -%}
          <div class="pvs-custom__swatch" {{ block.shopify_attributes }}>
            <div class="pvs-custom__swatch-color" style="background-color: {{ block.settings.swatch_color }};"></div>
            <div class="pvs-custom__swatch-name">{{ block.settings.swatch_name }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div style="text-align:center;margin-top:22px;">
      {%- if section.settings.custom_min_per_shade != blank -%}
        <p class="reveal" style="color:#e7d3bf;font-size:14px;">Minimum per custom shade: {{ section.settings.custom_min_per_shade }}. Lead time: {{ section.settings.custom_lead_time | default: 'To be confirmed' }}.</p>
      {%- else -%}
        <p><span style="background:var(--gold-pale);border:1px dashed var(--gold);color:#6b4a05;font-size:12px;border-radius:6px;padding:2px 8px;font-weight:600;">⚠ Confirm: minimum pieces per custom shade & typical lead-time</span></p>
      {%- endif -%}
      <div style="margin-top:16px;"><a class="pvs-custom__btn reveal" href="{{ wa_link }}" target="_blank" rel="noopener">Ask about custom colour</a></div>
    </div>
  </div>
</section>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Priyuja - Custom Colour",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Only possible from Varanasi"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your own colour"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro Text",
      "default": "Pick any shade from our colour chart and we weave it to order at our Varanasi looms — in the exact colour your customers are asking for. This is something we simply could not offer from Mumbai. It lets your boutique stand apart with colours no one else is stocking."
    },
    {
      "type": "text",
      "id": "custom_min_per_shade",
      "label": "⚠ Minimum pieces per custom shade",
      "info": "Leave blank until confirmed."
    },
    {
      "type": "text",
      "id": "custom_lead_time",
      "label": "⚠ Typical lead time (days)",
      "info": "Leave blank until confirmed."
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width (100%)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Custom Colour Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step title"
        },
        {
          "type": "textarea",
          "id": "step_text",
          "label": "Step Description",
          "default": "Step description."
        }
      ]
    },
    {
      "type": "swatch",
      "name": "Colour Swatch",
      "settings": [
        {
          "type": "color",
          "id": "swatch_color",
          "label": "Swatch Colour",
          "default": "#6B1628"
        },
        {
          "type": "text",
          "id": "swatch_name",
          "label": "Shade Name",
          "default": "Maroon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Priyuja - Custom Colour"
    }
  ]
}
{% endschema %}
