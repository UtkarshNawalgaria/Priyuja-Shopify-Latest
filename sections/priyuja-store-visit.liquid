{%- assign wa_link = section.settings.whatsapp_url | default: 'https://wa.me/919112044277' -%}

<style>
  #shopify-section-{{ section.id }} {
    --maroon: var(--priyuja-maroon);
    --maroon-deep: var(--priyuja-maroon-deep);
    --maroon-light: var(--priyuja-maroon-light);
    --gold: var(--priyuja-gold);
    --gold-light: var(--priyuja-gold-light);
    --gold-pale: var(--priyuja-gold-pale);
    --cream: var(--priyuja-cream);
    --dark: var(--priyuja-dark);
    --text-mid: var(--priyuja-text-mid);
    --text-light: var(--priyuja-text-light);
    --line: var(--priyuja-line, #E6DCC8);
    --card: var(--priyuja-card, #FFFFFF);
    --surface: var(--priyuja-surface, #FFFCF6);
    --font-heading: var(--priyuja-font-heading);
    --font-body: var(--priyuja-font-body);
    --section-max-width: {%- case section.settings.container_width -%}{%- when 'narrow' -%}840px{%- when 'wide' -%}1400px{%- when 'full' -%}100%{%- else -%}1180px{%- endcase -%};
    --section-v-pad: {%- case section.settings.section_padding -%}{%- when 'none' -%}0{%- when 'small' -%}32px{%- when 'large' -%}96px{%- else -%}54px{%- endcase -%};
    --heading-font-size: {%- case section.settings.heading_size -%}{%- when 'small' -%}18px{%- when 'large' -%}32px{%- else -%}24px{%- endcase -%};
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  .pvs-visit { font-family: var(--font-body); color: var(--dark); line-height: 1.65; background: var(--cream); padding: var(--section-v-pad) 0; border-bottom: 1px solid var(--line); }
  .pvs-visit h3 { font-family: var(--font-heading); color: var(--maroon); margin: 0; line-height: 1.12; }
  .pvs-visit__wrap { max-width: var(--section-max-width); margin: 0 auto; padding: 0 28px; }
  .pvs-visit__eyebrow { font-family: var(--font-body); letter-spacing: 2.5px; text-transform: uppercase; font-size: 12px; font-weight: 700; color: var(--gold); }
  .pvs-visit__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .pvs-visit__card { background: var(--card); border: 1px solid var(--line); border-radius: 12px; padding: 22px; }
  .pvs-visit__map { width: 100%; height: 200px; border: 0; border-radius: 8px; margin-top: 12px; }
  .pvs-visit__map-ph { width: 100%; background: linear-gradient(135deg, var(--maroon-deep) 0%, var(--maroon) 50%, var(--gold) 100%); border-radius: 12px; height: 200px; margin-top: 12px; display: flex; align-items: center; justify-content: center; color: var(--text-light); font-size: 13px; }
  .pvs-visit__btn { display: inline-block; padding: 13px 26px; border-radius: 7px; font-weight: 700; font-size: 14px; text-decoration: none; border: 1.5px solid var(--maroon); font-family: var(--font-body); cursor: pointer; transition: background 0.3s ease, transform 0.3s ease; background: var(--maroon); color: #fff; }
  .pvs-visit__btn:hover { background: var(--maroon-light); transform: translateY(-2px); }

  @media (max-width: 820px) {
    .pvs-visit__grid { grid-template-columns: 1fr !important; }
    .pvs-visit { padding: calc(var(--section-v-pad) * 0.65) 0; }
    .pvs-visit__wrap { padding: 0 18px; }
  }
</style>
{%- if section.settings.reverse_columns -%}
<style>
  #shopify-section-{{ section.id }} .pvs-visit__grid { direction: rtl; }
  #shopify-section-{{ section.id }} .pvs-visit__grid > * { direction: ltr; }
</style>
{%- endif -%}

<section class="pvs-visit">
  <div class="pvs-visit__wrap pvs-visit__grid">
    <div class="pvs-visit__card">
      <div class="pvs-visit__eyebrow">Visit our store</div>
      <h3 class="reveal" style="font-size:var(--heading-font-size);margin:6px 0 10px;">Priyuja — Varanasi</h3>
      {%- if section.settings.store_address != blank -%}
        <p class="reveal" style="color:var(--text-mid);">{{ section.settings.store_address }}<br>Varanasi, Uttar Pradesh</p>
      {%- else -%}
        <p><span style="background:var(--gold-pale);border:1px dashed var(--gold);color:#6b4a05;font-size:12px;border-radius:6px;padding:2px 8px;font-weight:600;">⚠ Add full Varanasi store address</span><br><span style="color:var(--text-mid);">Varanasi, Uttar Pradesh</span></p>
      {%- endif -%}
      <p class="reveal" style="color:var(--text-mid);">Phone / WhatsApp: +91 91120 44277<br>GSTIN: 27AADCO1764H1ZE</p>
      {%- if section.settings.map_embed_url != blank -%}
        <iframe class="pvs-visit__map" src="{{ section.settings.map_embed_url }}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Priyuja Varanasi Store Map"></iframe>
      {%- else -%}
        <div class="pvs-visit__map-ph">Google Map embed — add URL in settings</div>
      {%- endif -%}
    </div>
    <div class="pvs-visit__card">
      <div class="pvs-visit__eyebrow">Can't travel?</div>
      <h3 class="reveal" style="font-size:var(--heading-font-size);margin:6px 0 10px;">Book a video-call buying session</h3>
      <p class="reveal" style="color:var(--text-mid);">See the full collection live from your shop, pick ready stock or a custom shade, and confirm — no need to come to Varanasi.</p>
      {%- if section.settings.video_call_hours != blank -%}
        <p class="reveal" style="color:var(--text-mid);">Slots: {{ section.settings.video_call_hours }}</p>
      {%- else -%}
        <p>Slots: <span style="background:var(--gold-pale);border:1px dashed var(--gold);color:#6b4a05;font-size:12px;border-radius:6px;padding:2px 8px;font-weight:600;">⚠ Add call hours</span></p>
      {%- endif -%}
      <a class="pvs-visit__btn reveal" href="{{ wa_link }}" target="_blank" rel="noopener" style="margin-top:6px;">Book a video call</a>
    </div>
  </div>
</section>

{%- render 'priyuja-reveal', section_id: section.id -%}

{% schema %}
{
  "name": "Priyuja - Store Visit",
  "tag": "section",
  "class": "priyuja-section",
  "settings": [
    {
      "type": "text",
      "id": "store_address",
      "label": "⚠ Store Address (leave blank until confirmed)",
      "info": "Full Varanasi store address."
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Google Map Embed URL",
      "info": "Paste the 'src' URL from a Google Maps embed iframe."
    },
    {
      "type": "text",
      "id": "video_call_hours",
      "label": "⚠ Video Call Slot Hours",
      "info": "Leave blank until confirmed. E.g. 'Mon–Sat, 10 AM – 6 PM IST'."
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "narrow", "label": "Narrow (840px)" },
        { "value": "default", "label": "Default (1180px)" },
        { "value": "wide", "label": "Wide (1400px)" },
        { "value": "full", "label": "Full width (100%)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section padding",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Reverse column order",
      "default": false
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "presets": [
    {
      "name": "Priyuja - Store Visit"
    }
  ]
}
{% endschema %}
